# Copie para .env.local e preencha. Nunca commitar valores reais.

# Supabase (projeto "Viral Data" — app e corpus no mesmo projeto físico)
# URL do projeto Supabase — middleware.ts, lib/db.ts, lib/supabase/server.ts
NEXT_PUBLIC_SUPABASE_URL=
# Anon key (client + cookies de sessão) — middleware.ts, lib/supabase/server.ts
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role da identidade "app" (tabelas vm_*) — lib/db.ts (appDb)
SUPABASE_SERVICE_ROLE_KEY=
# URL da identidade "corpus" (mesmo projeto físico acima) — lib/db.ts (viralData)
VIRAL_DATA_URL=
# Service role read-mostly do corpus de 6k vídeos — lib/db.ts (viralData)
VIRAL_DATA_SERVICE_ROLE_KEY=

# LLMs
# Claude/Fable — lib/anthropic.ts (lido implicitamente pelo construtor do SDK)
ANTHROPIC_API_KEY=
# Grok (pesquisa da sala de roteiristas) — lib/grok.ts
GROK_API_KEY=

# Acesso
# Allowlist de e-mails com magic link (separados por vírgula) — lib/allowed-emails.ts
VM_ALLOWED_EMAILS=
# Segredo do cron semanal (Bearer) — app/api/cron/weekly-etl/route.ts
CRON_SECRET=

# Opcionais
# Embeddings do few-shot do pipeline — lib/pipeline/context.ts, scripts/backfill-embeddings.ts
OPENAI_API_KEY=
# Transcrição de Reels/TikTok — app/api/transcribe-link/route.ts
SUPADATA_API_KEY=
# Override do modelo de rascunho/humanização (default: claude-fable-5) — lib/anthropic.ts
VM_WRITER_MODEL=
# Override do modelo de análise/crítica (default: claude-sonnet-5) — lib/anthropic.ts
VM_ANALYST_MODEL=
# API do TL;dv, só para o script manual de import de preferências — scripts/import-tldv-preferences.ts
TLDV_API_KEY=
